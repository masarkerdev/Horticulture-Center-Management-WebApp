# ============================================================
# উদ্যানতত্ত্ব কেন্দ্র - ENVIRONMENT VARIABLES
# 
# কিভাবে পাবেন:
# Supabase Dashboard > Settings > Database > Connection String (URI)
# ============================================================

# Supabase Database URL
# Supabase Dashboard > Settings > Database > Connection string > URI
# এটা দেখতে এরকম হবে:
DATABASE_URL=postgresql://postgres.xxxxx:your_password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# JWT Secret — যেকোনো লম্বা random text দিন
JWT_SECRET=horticulture_asambasti_rangamati_secret_2024_change_this

# JWT Token মেয়াদ
JWT_EXPIRES_IN=7d

# Server Port (local-এ)
PORT=5000
